# LiveKit
LIVEKIT_URL=wss://example.livekit.cloud
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me

# LLM/STT/TTS providers
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=replace_me
TTS_PROVIDER=openai
OPENAI_TTS_VOICE=nova

# OpenMRS bridge / backend gateway
AGENT_BACKEND_URL=http://localhost:3001/api/v1
AGENT_INTERNAL_SECRET=replace_me

# Clinical safety defaults
ENABLE_CONTENT_MODERATION=true
ENABLE_TRANSCRIPT_SAVE=false
TRANSCRIPT_REDACTION_ENABLED=true
TRANSCRIPT_RAW_STORAGE_ALLOWED=false
LOG_LEVEL=INFO
LOG_FORMAT=json
